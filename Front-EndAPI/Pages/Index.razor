@page "/"
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider

<h3>Welcome</h3>

@if (User is null || !User.Identity.IsAuthenticated)
{
    <p>No user logged in.</p>
    <a href="/login">Go to Login</a>
}
else
{
    <p><b>User:</b> @User.Identity.Name</p>

    <p><b>Permissions:</b></p>
    <ul>
        @foreach (var role in RolesList)
        {
            <li>@role</li>
        }
    </ul>

    <h4>Actions</h4>

    <button disabled="@(!HasPermission(Roles.ViewDashboard))">View Dashboard</button>
    <button disabled="@(!HasPermission(Roles.EditUsers))">Edit Users</button>
    <button disabled="@(!HasPermission(Roles.DeleteRecords))">Delete Records</button>
}

@code {
    private ClaimsPrincipal User;
    private List<string> RolesList = new();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        User = state.User;

        RolesList = User.Claims
            .Where(c => c.Type == "role")
            .Select(c => c.Value)
            .ToList();
    }

    private bool HasPermission(Roles role)
        => User.Claims.Any(c => c.Type == "role" && c.Value == role.ToString());
}
